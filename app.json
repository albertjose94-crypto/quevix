{
  "expo": {
    "name": "Quevix Queue",
    "slug": "quevix-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quevix.queue"
    },
    "android": {
      "package": "com.quevix.queue",
      "versionCode": 2,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-notifications"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "extra": {
      "eas": {
        "projectId": "d98022c5-4a48-46c1-a97c-31a244b74ca0"
      }
    }
  }
}
